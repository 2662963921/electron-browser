{
  "name": "electron-browser",
  "version": "1.0.0",
  "description": "Windows Electron WebView Browser with advanced controls",
  "author": "User",
  "main": "main.js",
  "scripts": {
    "start": "node start.js .",
    "build": "set ELECTRON_MIRROR=https://npmmirror.com/mirrors/electron/ && set ELECTRON_CACHE=%USERPROFILE%\\.electron-cache && electron-builder --win portable"
  },
  "build": {
    "appId": "com.electron.browser",
    "productName": "WebView 浏览器",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": ["portable"],
      "icon": null,
      "requestedExecutionLevel": "asInvoker"
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "error.html"
    ]
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^26.15.3"
  }
}
