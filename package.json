{
  "name": "electron-browser",
  "version": "1.0.0",
  "description": "Windows Electron WebView Browser with advanced controls",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win portable",
    "build:installer": "electron-builder --win"
  },
  "build": {
    "appId": "com.electron.browser",
    "productName": "WebView Browser",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": ["portable", "nsis"],
      "icon": null
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "error.html"
    ]
  },
  "devDependencies": {
    "electron": "^28.0.0"
  }
}
